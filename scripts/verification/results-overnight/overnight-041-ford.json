  "criticalFindings": [
    {
      "severity": "CRITICAL",
      "issue": "1997-1998 F-250 entries have wrong bolt pattern (8x170)",
      "details": "Ford F-250 Super Duty with 8x170 bolt pattern didn't exist until 1999. The 1997-1998 F-250 was either: (1) Old body style with 8x165.1mm, or (2) F-250 Light Duty with 7x150mm / 87.1mm hub bore. All 6 entries for 1997-1998 are INVALID.",
      "affectedCount": 6,
      "sources": ["hulkoffsets.com", "jimburkeford.com", "performanceplustire.com"]
    },
    {
      "severity": "HIGH",
      "issue": "1994-1996 entries have wrong tire sizes (17\"/18\"/20\" on 16\" vehicles)",
      "details": "The 1994-1996 F-250 only came with 16\" wheels. Batch shows LT245/75R17, LT265/70R17, LT275/70R18, etc. Correct OEM sizes: 215/85R16, 235/85R16, 265/75R16.",
      "affectedCount": 9,
      "sources": ["tiresize.com", "hulkoffsets.com"]
    },
    {
      "severity": "HIGH",
      "issue": "1999-2007 Super Duty wheel/tire diameter mismatches",
      "details": "Most entries show 17\" or 18\" wheel diameters but include tire sizes for 20\" wheels (LT275/65R20, 275/65R20). 1999-2007 Super Duty OEM was primarily 16\"-17\" with some 18\" options introduced around 2005.",
      "affectedCount": 47,
      "sources": ["tiresize.com", "hulkoffsets.com"]
    },
    {
      "severity": "MEDIUM",
      "issue": "Inherited tire data appears to be from later model years",
      "details": "Source 'generation_inherit' applied later Super Duty tire specs (2011+) retroactively to 1994-2010 models. LT285/75R18 option wasn't available until 2011+ generation.",
      "affectedCount": 60,
      "sources": ["tiresize.com"]
    }
  ],
