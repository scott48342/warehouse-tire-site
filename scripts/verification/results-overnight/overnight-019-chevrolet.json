  "criticalIssues": [
    {
      "issue": "2014-2026 Silverado (generic) has wrong bolt pattern and hub bore",
      "details": "Batch shows 5x120 bolt pattern with 67.1mm hub bore. Correct specs: 6x139.7 bolt pattern, 78.1mm hub bore. The 5x120/67.1mm is Camaro/Malibu pattern, not Silverado.",
      "affectedVehicles": 14,
      "severity": "CRITICAL"
    },
    {
      "issue": "1985-1988 Nova has completely wrong fitment data",
      "details": "These years were NUMMI-built Toyota Corolla-based FWD cars with 4x100 bolt pattern. Batch shows RWD GM specs (5x120.65, 70.3mm hub bore). Also, trims like 'SS', 'Rally', 'Custom' did not exist for NUMMI Nova.",
      "affectedVehicles": 12,
      "severity": "CRITICAL"
    },
    {
      "issue": "1988-1989 Silverado-1500 model name is anachronistic",
      "details": "The 'Silverado 1500' model name didn't exist until 1999. Pre-1999 trucks were C/K series (C1500, K1500). 'Silverado' was a trim level, not model name.",
      "affectedVehicles": 12,
      "severity": "MODERATE"
    }
  ],
  "sources": [
    "tirewheelguide.com",
    "Wikipedia (Chevrolet Chevy II / Nova, Chevrolet Silverado)",
    "wheel-sizes.com",
    "BB Wheels (1985-1988 Nova 4x100 confirmation)"
  ],
