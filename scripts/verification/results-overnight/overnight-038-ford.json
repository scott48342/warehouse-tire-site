    {
      "issue": "16-inch tire sizes included for 2005-2014 models",
      "description": "The 11th (2004-2008) and 12th (2009-2014) generation F-150s did NOT come with 16-inch wheels from the factory. The 16-inch wheel option was only available on the 10th generation (1997-2003). Sizes like 245/75R16 and 265/75R16 should be removed from 2005-2014 F-150 fitments.",
      "affectedVehicles": 56,
      "severity": "HIGH"
    },
    {
      "issue": "Raptor tire sizes are incorrect",
      "description": "All Raptor models (2010-2013) should have 315/70R17 as the OEM tire size, not generic F-150 sizes. The 17x8.5 wheel is also unique to Raptor.",
      "affectedVehicles": 4,
      "severity": "HIGH"
    },
    {
      "issue": "Limited trim wheel width may be incorrect",
      "description": "2013 F-150 Limited came with 22-inch wheels. The 9-inch width listed seems high - typical Limited wheels were 22x9, but offset data should be verified.",
      "affectedVehicles": 1,
      "severity": "MEDIUM"
    }
