    },
    {
      "issue": "INVALID_MODEL_YEAR",
      "severity": "critical",
      "count": 2,
      "description": "1988-1989 Silverado 3500HD did not exist. The 'Silverado' model name started in 1999. Pre-1999 trucks were 'C/K 3500' with Silverado trim level.",
      "affectedVehicles": "1988-1989 silverado-3500hd"
    }
