  "findings": {
    "criticalIssues": [
      {
        "issue": "1997-1998 F-350 bolt pattern WRONG",
        "details": "Data shows 8x170 but these years used 8x165.1. Ford Super Duty with 8x170 started in 1999. The 1997-1998 F-350 was still the old body style.",
        "affectedVehicles": 6,
        "severity": "INVALID"
      },
      {
        "issue": "1988-1996 F-350 tire sizes WRONG",
        "details": "Tire sizes show modern 17/18/20 inch sizes (LT245/75R17, LT265/70R17, etc.) but this era only had 16 inch wheels. Correct sizes: LT215/85R16, LT235/85R16",
        "affectedVehicles": 31,
        "severity": "FLAGGED"
      }
    ],
    "notes": [
      "2023-2026 F-250 Super Duty: Bolt pattern (8x170), hub bore (124.9mm) verified correct",
      "Ford Super Duty 8x170 bolt pattern confirmed starting 1999 model year",
      "1988-1997 Ford F-350 used 8x165.1 (8x6.5 inch) bolt pattern",
      "Some 'generation_inherit' entries inherited incorrect modern tire sizes for older vehicles"
    ]
  },
