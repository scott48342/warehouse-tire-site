    "criticalIssues": [
      {
        "issue": "F-450 Super Duty 2006-2014 has completely wrong fitment data",
        "description": "Batch shows 5x114.3 bolt pattern (passenger car pattern) for a heavy-duty commercial truck. Correct pattern is 10x225mm with 170.1mm hub bore. This data is dangerous and unusable.",
        "affectedCount": 9,
        "severity": "critical"
      },
      {
        "issue": "Ford Fiesta 2000-2010 not sold in US market",
        "description": "Fiesta was not available in US from 2000-2010. It returned as 2011 model year. These entries represent non-existent vehicles for US market. Additionally, fitment specs shown (5x114.3, 67.1mm) are wrong even for European models (should be 4x108, 63.4mm).",
        "affectedCount": 11,
        "severity": "critical"
      },
      {
        "issue": "Ford Fiesta 2020-2024 discontinued in US",
        "description": "Fiesta was discontinued in US after 2019 model year. These vehicles don't exist in US market. Fitment specs are also incorrect.",
        "affectedCount": 5,
        "severity": "critical"
      },
      {
        "issue": "Ford Flex 2008 model year does not exist",
        "description": "Ford Flex production started in late 2008 for 2009 model year. There is no 2008 Flex. Additionally, hub bore shown (67.1mm) is incorrect - should be 63.4mm.",
        "affectedCount": 1,
        "severity": "critical"
      }
    ],
    "notes": [
      "F-450 2015-2026 entries have correct commercial truck fitment data",
      "F-450 2026 may be a future model year - verify when released",
      "Ford Focus 2000-2012 entries all have correct fitment data",
      "Focus 4x108 (2000-2011) and 5x108 (2012+) patterns are properly differentiated"
    ]
  },
