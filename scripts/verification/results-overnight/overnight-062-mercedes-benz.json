  "issues": [
    {
      "severity": "critical",
      "affectedVehicles": 18,
      "model": "e-class-amg",
      "years": "2002-2019",
      "issue": "Wrong bolt pattern and hub bore",
      "currentValues": {
        "boltPattern": "5x114.3",
        "hubBore": "67.1"
      },
      "correctValues": {
        "boltPattern": "5x112",
        "hubBore": "66.6"
      },
      "explanation": "5x114.3 is a Japanese market bolt pattern (Honda, Acura, Lexus, Nissan). Mercedes-Benz has never used this pattern. All Mercedes E-Class including AMG variants use 5x112 bolt pattern with 66.6mm hub bore."
    }
  ],
