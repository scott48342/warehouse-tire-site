  "criticalIssues": [
    {
      "issue": "E-150/E-250 Econoline tire sizes completely wrong",
      "description": "All E-150 and E-250 models show 205/55R16 which is a compact car tire. These full-size vans require 225/75R16, 235/70R16, 235/75R15, or 245/75R16",
      "affectedCount": 25,
      "severity": "CRITICAL"
    },
    {
      "issue": "E-350 Econoline bolt pattern wrong",
      "description": "All E-350 models (2000-2019) show 5x114.3 bolt pattern but should be 8x165.1 (8x6.5\"). E-350 is a heavy-duty van with 8-lug wheels",
      "affectedCount": 20,
      "severity": "CRITICAL"
    },
    {
      "issue": "E-350 Econoline hub bore wrong",
      "description": "Hub bore shown as 67.1mm but should be approximately 130.8mm (5.15\") for 8-lug Ford vans",
      "affectedCount": 20,
      "severity": "CRITICAL"
    }
  ],
  "sourcesCited": [
