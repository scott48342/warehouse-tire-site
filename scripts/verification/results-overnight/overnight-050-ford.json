    {
      "issue": "BOLT_PATTERN_ERROR",
      "description": "1994-1999 Mustang trims incorrectly show 4x108 bolt pattern. Ford switched ALL Mustangs to 5x114.3 (5-lug) starting in 1994. Only the 1993 model year should have 4x108.",
      "affectedVehicles": 30,
      "correctValue": "5x114.3",
      "sources": [
        "https://lmr.com/products/mustang-wheel-torque-specs",
        "https://www.americanmuscle.com/wheel-tech-guide.html",
        "https://factorywheelwarehouse.com"
      ]
    },
    {
      "issue": "HUB_BORE_ERROR",
      "description": "1994-1999 Mustangs show 63.4mm hub bore but should be 70.3mm for the 5-lug SN95 platform",
      "affectedVehicles": 30,
      "correctValue": "70.3",
      "sources": [
        "https://www.americanmuscle.com/wheel-tech-guide.html"
      ]
    },
